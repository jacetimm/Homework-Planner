<div class="min-h-screen bg-slate-50 py-16 px-4 font-sans">
  <div class="max-w-2xl mx-auto">

    <!-- Back link -->
    <div class="mb-8">
      <%= link_to "← Back", root_path, class: "text-sm font-semibold text-slate-400 hover:text-indigo-600 transition-colors" %>
    </div>

    <!-- Header -->
    <div class="mb-10">
      <div class="inline-flex items-center gap-2 bg-indigo-50 border border-indigo-100 rounded-full px-3 py-1 mb-4">
        <span class="text-xs font-bold uppercase tracking-wider text-indigo-600">Legal</span>
      </div>
      <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight mb-3">Terms of Service</h1>
      <p class="text-sm text-slate-400 font-medium">Last updated: March 25, 2026</p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 divide-y divide-slate-100 overflow-hidden">

      <div class="px-8 py-7">
        <h2 class="text-base font-extrabold text-slate-900 mb-2">Service</h2>
        <p class="text-sm text-slate-600 leading-relaxed">Homework Planner is a free tool that helps students organize their homework using data from Google Classroom. The service is provided as-is with no guarantees.</p>
      </div>

      <div class="px-8 py-7">
        <h2 class="text-base font-extrabold text-slate-900 mb-2">Your responsibilities</h2>
        <p class="text-sm text-slate-600 leading-relaxed">You are responsible for completing your own assignments. Homework Planner provides estimates and scheduling suggestions but does not guarantee accuracy of time estimates or scheduling.</p>
      </div>

      <div class="px-8 py-7">
        <h2 class="text-base font-extrabold text-slate-900 mb-2">Data usage</h2>
        <p class="text-sm text-slate-600 leading-relaxed">By using this app, you agree to let us access your Google Classroom, Calendar, and Drive data in read-only mode to provide the planning service. See our <a href="/privacy" class="font-semibold text-indigo-600 hover:text-indigo-800 transition-colors">Privacy Policy</a> for details.</p>
      </div>

      <div class="px-8 py-7">
        <h2 class="text-base font-extrabold text-slate-900 mb-2">Changes</h2>
        <p class="text-sm text-slate-600 leading-relaxed">We may update these terms at any time. Continued use of the app means you accept the updated terms.</p>
      </div>

      <div class="px-8 py-7">
        <h2 class="text-base font-extrabold text-slate-900 mb-2">Contact</h2>
        <p class="text-sm text-slate-600 leading-relaxed">Questions? Email <a href="mailto:jacetimm@gmail.com" class="font-semibold text-indigo-600 hover:text-indigo-800 transition-colors">jacetimm@gmail.com</a>.</p>
      </div>

    </div>

    <!-- Footer links -->
    <p class="mt-8 text-center text-xs text-slate-400">
      Also see our <%= link_to "Privacy Policy", "/privacy", class: "font-semibold text-slate-500 hover:text-indigo-600 underline underline-offset-2 transition-colors" %>.
    </p>

  </div>
</div>
