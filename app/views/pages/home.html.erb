<% content_for :title, "Homework Planner — Plan your homework night in seconds" %>

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-slate-900 to-indigo-900 flex flex-col">

  <!-- Nav -->
  <nav class="flex items-center justify-between px-6 sm:px-10 py-5">
    <div class="flex items-center gap-2.5">
      <div class="w-8 h-8 bg-indigo-500 rounded-xl flex items-center justify-center shadow-lg">
        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
      </div>
      <span class="text-white font-extrabold text-lg tracking-tight">Homework Planner</span>
    </div>
    <%= button_to '/auth/google_oauth2', method: :post, data: { turbo: false },
          class: "px-4 py-2 rounded-xl bg-white/10 hover:bg-white/20 border border-white/20 text-white text-sm font-semibold transition" do %>
      Sign in
    <% end %>
  </nav>

  <!-- Hero -->
  <main class="flex-1 flex flex-col items-center justify-center px-6 text-center py-4 sm:py-12">
    <div class="max-w-2xl mx-auto w-full">

      <div class="inline-flex items-center gap-2 bg-indigo-500/20 border border-indigo-400/30 rounded-full px-4 py-1.5 mb-4 sm:mb-6">
        <div class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></div>
        <span class="text-indigo-300 text-xs font-semibold tracking-wide">Free for students</span>
      </div>

      <h1 class="text-3xl sm:text-5xl font-extrabold text-white leading-tight tracking-tight mb-3 sm:mb-4">
        Plan your homework night<br class="hidden sm:block"> in seconds
      </h1>
      <p class="text-base sm:text-lg text-indigo-200/80 mb-5 sm:mb-10 max-w-xl mx-auto leading-relaxed">
        Connects to Google Classroom, estimates how long assignments take, and builds a study schedule around your calendar.
      </p>

      <!-- Feature grid — 2×2 on mobile, 1×4 on desktop -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3 mb-5 sm:mb-10 text-left">
        <div class="bg-white/8 border border-white/10 rounded-2xl p-3 sm:p-4">
          <div class="w-7 h-7 sm:w-8 sm:h-8 bg-indigo-500/30 rounded-xl flex items-center justify-center mb-2 sm:mb-3">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <p class="text-white font-bold text-xs sm:text-sm mb-0.5">Smart Scheduling</p>
          <p class="text-white/50 text-xs leading-snug hidden sm:block">Spreads work across nights so you're never overwhelmed</p>
          <p class="text-white/50 text-[10px] leading-snug sm:hidden">Spreads work so you're never overwhelmed</p>
        </div>
        <div class="bg-white/8 border border-white/10 rounded-2xl p-3 sm:p-4">
          <div class="w-7 h-7 sm:w-8 sm:h-8 bg-violet-500/30 rounded-xl flex items-center justify-center mb-2 sm:mb-3">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-violet-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <p class="text-white font-bold text-xs sm:text-sm mb-0.5">AI Time Estimates</p>
          <p class="text-white/50 text-xs leading-snug hidden sm:block">Groq AI reads each assignment and predicts how long it'll take</p>
          <p class="text-white/50 text-[10px] leading-snug sm:hidden">AI predicts how long each task takes</p>
        </div>
        <div class="bg-white/8 border border-white/10 rounded-2xl p-3 sm:p-4">
          <div class="w-7 h-7 sm:w-8 sm:h-8 bg-emerald-500/30 rounded-xl flex items-center justify-center mb-2 sm:mb-3">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <p class="text-white font-bold text-xs sm:text-sm mb-0.5">Calendar-Aware</p>
          <p class="text-white/50 text-xs leading-snug hidden sm:block">Blocks out events from Google Calendar so study time actually fits</p>
          <p class="text-white/50 text-[10px] leading-snug sm:hidden">Works around your Google Calendar</p>
        </div>
        <div class="bg-white/8 border border-white/10 rounded-2xl p-3 sm:p-4">
          <div class="w-7 h-7 sm:w-8 sm:h-8 bg-rose-500/30 rounded-xl flex items-center justify-center mb-2 sm:mb-3">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-rose-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <p class="text-white font-bold text-xs sm:text-sm mb-0.5">Crunch Mode</p>
          <p class="text-white/50 text-xs leading-snug hidden sm:block">Breaks last-minute assignments into microtasks you can actually finish</p>
          <p class="text-white/50 text-[10px] leading-snug sm:hidden">Breaks last-minute work into microtasks</p>
        </div>
      </div>

      <!-- CTA -->
      <%= button_to '/auth/google_oauth2', method: :post, data: { turbo: false },
            class: "inline-flex items-center gap-3 bg-slate-800 hover:bg-slate-700 text-white font-bold px-6 sm:px-7 py-3 sm:py-3.5 rounded-2xl shadow-xl transition text-sm sm:text-base border border-white/10" do %>
        <svg class="w-4 h-4 sm:w-5 sm:h-5" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Get Started with Google
      <% end %>

      <p class="mt-3 sm:mt-4 text-xs text-white/30">Free to use &middot; No credit card required</p>
    </div>
  </main>

  <!-- Footer -->
  <footer class="px-6 py-3 sm:py-5 flex items-center justify-center gap-6 border-t border-white/8">
    <%= link_to "Privacy Policy", privacy_path, class: "text-xs text-white/40 hover:text-white/70 transition" %>
    <%= link_to "Terms of Service", terms_path, class: "text-xs text-white/40 hover:text-white/70 transition" %>
  </footer>

</div>
