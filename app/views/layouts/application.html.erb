<!DOCTYPE html>
<html id="html-root">
  <head>
    <title><%= content_for(:title) || "Homework Planner" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%# Apply theme immediately before paint to avoid flash of wrong theme %>
    <script>
    (function() {
      var serverTheme = '<%= (@user_setting || current_user&.user_setting)&.color_theme&.gsub("'", "") || "auto" %>';
      var isOnboarding = <%= current_user && !(@user_setting || current_user.user_setting)&.onboarding_completed? ? 'true' : 'false' %>;
      var theme = 'auto';
      
      try {
        var draft = localStorage.getItem('onb_draft_theme');
        if (draft) {
          theme = draft;
        } else if (isOnboarding) {
          theme = 'light'; // Neutral default before choice is made
        } else {
          theme = serverTheme;
        }
      } catch(e) {
        theme = isOnboarding ? 'light' : serverTheme;
      }
      
      var dark  = theme === 'dark' || (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
      if (dark) {
        document.documentElement.classList.add('dark');
        document.documentElement.style.colorScheme = 'dark';
      } else {
        document.documentElement.classList.remove('dark');
        document.documentElement.style.colorScheme = 'light';
      }
      if (theme === 'auto') {
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
          if (e.matches) {
            document.documentElement.classList.add('dark');
            document.documentElement.style.colorScheme = 'dark';
          } else {
            document.documentElement.classList.remove('dark');
            document.documentElement.style.colorScheme = 'light';
          }
        });
      }
    })();
    </script>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <% vapid_key = Rails.application.credentials.dig(:vapid, :public_key) %>
    <% if vapid_key.present? %>
      <meta name="vapid-public-key" content="<%= vapid_key %>">
    <% end %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100 font-sans selection:bg-indigo-100 pb-16 md:pb-0">

    <% if current_user %>
      <!-- Shared Sticky Navbar (desktop only) -->
      <nav class="hidden md:block bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-40">
        <div class="w-full max-w-[1700px] mx-auto px-6 sm:px-10 lg:px-16">
          <div class="flex items-center justify-between h-16">

            <!-- Logo + Primary Nav Links -->
            <div class="flex items-center gap-5">
              <%= link_to root_path, class: "flex items-center gap-2.5 group flex-shrink-0" do %>
                <div class="bg-indigo-600 p-1.5 rounded-lg text-white shadow-sm group-hover:bg-indigo-700 transition">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                </div>
                <span class="font-bold text-slate-900 dark:text-slate-100 text-sm hidden sm:block tracking-tight">Homework Planner</span>
              <% end %>

              <div class="hidden sm:flex items-center gap-0.5">
                <%= link_to "Dashboard", root_path, class: "text-sm font-semibold px-3 py-1.5 rounded-lg transition #{controller_name == 'dashboard' ? 'text-indigo-600 bg-indigo-50' : 'text-slate-500 hover:text-slate-800 hover:bg-slate-100'}" %>
                <a href="https://calendar.google.com" target="_blank" rel="noopener" class="text-sm font-semibold px-3 py-1.5 rounded-lg transition text-slate-500 hover:text-slate-800 hover:bg-slate-100 flex items-center gap-1">
                  Calendar
                  <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
                <%= link_to "Preferences", settings_path, class: "text-sm font-semibold px-3 py-1.5 rounded-lg transition #{controller_name == 'settings' ? 'text-indigo-600 bg-indigo-50' : 'text-slate-500 hover:text-slate-800 hover:bg-slate-100'}" %>
              </div>
            </div>

            <!-- User Info + Logout -->
            <div class="flex items-center gap-2">
              <span class="hidden md:flex items-center text-xs font-medium text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-700 px-3 py-1.5 rounded-full border border-slate-200 dark:border-slate-600">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1.5 flex-shrink-0"></span>
                <%= current_user.email %>
              </span>
              <%= button_to "Logout", logout_path, method: :delete, data: { turbo: false }, class: "text-sm font-semibold text-slate-500 hover:text-rose-600 py-1.5 px-3 rounded-lg hover:bg-rose-50 transition cursor-pointer" %>
            </div>

          </div>
        </div>
      </nav>
    <% end %>

    <!-- Flash Toasts (dismissible, auto-hide) -->
    <% if flash[:notice].present? %>
      <div id="flash-notice" class="fixed top-4 md:top-20 right-4 z-50 max-w-sm w-full animate-[fadeIn_0.2s_ease-out]" role="alert">
        <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-2xl shadow-lg px-4 py-3 flex items-start gap-3">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <p class="text-sm font-medium flex-1"><%= flash[:notice] %></p>
          <button onclick="this.closest('#flash-notice').remove()" class="text-emerald-400 hover:text-emerald-700 flex-shrink-0 leading-none text-lg">&times;</button>
        </div>
      </div>
      <script>setTimeout(function(){ var el = document.getElementById('flash-notice'); if(el){ el.style.transition='opacity 0.4s'; el.style.opacity='0'; setTimeout(function(){ el.remove(); }, 400); } }, 4000);</script>
    <% end %>

    <% if flash[:alert].present? %>
      <div id="flash-alert" class="fixed top-4 md:top-20 right-4 z-50 max-w-sm w-full" role="alert">
        <div class="bg-rose-50 border border-rose-200 text-rose-800 rounded-2xl shadow-lg px-4 py-3 flex items-start gap-3">
          <svg class="w-5 h-5 text-rose-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <p class="text-sm font-medium flex-1"><%= flash[:alert] %></p>
          <button onclick="this.closest('#flash-alert').remove()" class="text-rose-400 hover:text-rose-700 flex-shrink-0 leading-none text-lg">&times;</button>
        </div>
      </div>
      <script>setTimeout(function(){ var el = document.getElementById('flash-alert'); if(el){ el.style.transition='opacity 0.4s'; el.style.opacity='0'; setTimeout(function(){ el.remove(); }, 400); } }, 6000);</script>
    <% end %>

    <% if current_user %>
      <!-- switchMobileTab must be defined before yield so dashboard's auto-switch IIFE can call it -->
      <script>
      function switchMobileTab(tab) {
        var tonight = document.getElementById('mobile-tonight-view');
        var weekly  = document.getElementById('mobile-weekly-view');

        // Not on the dashboard — navigate there with the desired tab as a param
        if (!tonight || !weekly) {
          window.location.href = '/' + (tab === 'weekly' ? '?tab=weekly' : '');
          return;
        }

        var btnT    = document.getElementById('nav-btn-tonight');
        var btnW    = document.getElementById('nav-btn-weekly');
        var activeClass   = 'flex-1 flex flex-col items-center gap-0.5 py-2.5 text-indigo-600 transition';
        var inactiveClass = 'flex-1 flex flex-col items-center gap-0.5 py-2.5 text-slate-400 transition';
        if (tab === 'tonight') {
          tonight.classList.remove('hidden');
          weekly.classList.add('hidden');
          if (btnT) btnT.className = activeClass;
          if (btnW) btnW.className = inactiveClass;
        } else {
          tonight.classList.add('hidden');
          weekly.classList.remove('hidden');
          if (btnW) btnW.className = activeClass;
          if (btnT) btnT.className = inactiveClass;
        }
      }
      </script>
    <% end %>

    <%= yield %>

    <% if current_user %>
      <!-- Mobile bottom nav bar (hidden on md+) -->
      <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-white dark:bg-slate-800 border-t border-slate-200 dark:border-slate-700 safe-area-inset-bottom">
        <div class="flex">
          <button id="nav-btn-tonight" onclick="switchMobileTab('tonight')"
                  class="flex-1 flex flex-col items-center gap-0.5 py-2.5 <%= controller_name == 'dashboard' ? 'text-indigo-600' : 'text-slate-400' %> transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            <span class="text-[10px] font-bold">Tonight</span>
          </button>
          <button id="nav-btn-weekly" onclick="switchMobileTab('weekly')"
                  class="flex-1 flex flex-col items-center gap-0.5 py-2.5 text-slate-400 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            <span class="text-[10px] font-bold">Weekly</span>
          </button>
          <a href="<%= settings_path %>"
             class="flex-1 flex flex-col items-center gap-0.5 py-2.5 <%= controller_name == 'settings' ? 'text-indigo-600' : 'text-slate-400' %> transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-[10px] font-bold">Settings</span>
          </a>
        </div>
      </nav>

    <% end %>

    <% if current_user %>
      <!-- Service Worker & Push Notification Support -->
      <script>
      (function() {
        if (!('serviceWorker' in navigator) || !('PushManager' in window) || !('Notification' in window)) return;

        // Always read these fresh from the DOM — never cache in a closure variable
        // so stale values from a prior page load can't cause silent failures.
        function vapidKey()  { var m = document.querySelector('meta[name="vapid-public-key"]');  return m ? m.content : null; }
        function csrfToken() { var m = document.querySelector('meta[name="csrf-token"]');         return m ? m.content : null; }

        function b64ToUint8(str) {
          var pad = '='.repeat((4 - str.length % 4) % 4);
          var raw = atob((str + pad).replace(/-/g, '+').replace(/_/g, '/'));
          var arr = new Uint8Array(raw.length);
          for (var i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
          return arr;
        }

        // Core: subscribe and POST to server. Always uses navigator.serviceWorker.ready.
        function doSubscribe() {
          var key = vapidKey();
          if (!key) { console.warn('[Push] vapid-public-key meta tag missing or empty'); return; }
          console.log('[Push] doSubscribe() starting, waiting for SW ready...');
          navigator.serviceWorker.ready.then(function(reg) {
            console.log('[Push] SW ready, calling pushManager.subscribe()');
            return reg.pushManager.subscribe({
              userVisibleOnly: true,
              applicationServerKey: b64ToUint8(key)
            });
          }).then(function(sub) {
            console.log('[Push] subscribed:', sub.endpoint);
            var j = sub.toJSON();
            return fetch('/push_subscriptions', {
              method:  'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken() },
              body:    JSON.stringify({ endpoint: j.endpoint, p256dh_key: j.keys && j.keys.p256dh, auth_key: j.keys && j.keys.auth })
            });
          }).then(function(r) {
            console.log('[Push] subscription saved, status:', r.status);
          }).catch(function(err) {
            console.warn('[Push] doSubscribe failed:', err);
          });
        }

        function doUnsubscribe() {
          navigator.serviceWorker.ready.then(function(reg) {
            return reg.pushManager.getSubscription();
          }).then(function(sub) {
            if (!sub) return;
            var endpoint = sub.endpoint;
            return sub.unsubscribe().then(function() {
              fetch('/push_subscriptions/unsubscribe', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken() },
                body: JSON.stringify({ endpoint: endpoint })
              });
            });
          }).catch(function() {});
        }

        // Settings toggle
        window.togglePushNotifications = function(enabled) {
          if (!enabled) { doUnsubscribe(); return; }
          if (Notification.permission === 'granted') { doSubscribe(); return; }
          // Need to ask first — requestPermission must come from a user gesture,
          // so the settings checkbox click counts as one.
          Notification.requestPermission().then(function(p) {
            if (p === 'granted') doSubscribe();
          }).catch(function() {});
        };

        // Register SW early so it's active before user clicks Allow
        navigator.serviceWorker.register('/service-worker').catch(function(err) {
          console.warn('[Push] SW registration failed:', err);
        });

        // If already granted on page load, make sure subscription is current
        if (Notification.permission === 'granted' && vapidKey()) {
          navigator.serviceWorker.ready.then(function(reg) {
            return reg.pushManager.getSubscription();
          }).then(function(sub) {
            if (!sub) doSubscribe();
          }).catch(function() {});
        }

        // Expose for onboarding completion handler
        window.doSubscribePush = doSubscribe;
      })();
      </script>
    <% end %>

    <% if current_user %>
    <!-- Push Notification Permission Prompt (shown via JS) -->
    <div id="push-prompt" class="hidden fixed bottom-20 md:bottom-6 left-4 right-4 md:left-auto md:right-6 md:max-w-sm z-50">
      <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl shadow-xl p-4 flex gap-3 items-start">
        <div class="p-2 bg-indigo-100 dark:bg-indigo-900/40 rounded-lg flex-shrink-0">
          <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-bold text-slate-900 dark:text-slate-100">Want reminders when assignments are due soon?</p>
          <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">We'll nudge you before deadlines so nothing sneaks up on you.</p>
          <div class="flex gap-2 mt-3">
            <button id="push-prompt-allow" type="button" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-bold py-2 px-3 rounded-xl transition">Allow</button>
            <button onclick="(function(){var el=document.getElementById('push-prompt');if(el)el.remove();localStorage.setItem('push_prompt_dismissed','1');})()" class="flex-1 bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-700 dark:text-slate-300 text-sm font-bold py-2 px-3 rounded-xl transition">Not now</button>
          </div>
        </div>
        <button onclick="(function(){var el=document.getElementById('push-prompt');if(el)el.remove();localStorage.setItem('push_prompt_dismissed','1');})()" class="text-slate-400 hover:text-slate-600 flex-shrink-0 leading-none text-lg -mt-0.5">&times;</button>
      </div>
    </div>
    <!-- Shown if user denies permission -->
    <div id="push-denied-msg" class="hidden fixed bottom-20 md:bottom-6 left-4 right-4 md:left-auto md:right-6 md:max-w-sm z-50">
      <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl shadow-xl p-4 flex gap-3 items-start">
        <div class="flex-1 min-w-0">
          <p class="text-sm text-slate-600 dark:text-slate-300">You can enable notifications later in <a href="/settings#notifications-section" class="font-bold text-indigo-600 underline">Settings</a>.</p>
        </div>
        <button onclick="document.getElementById('push-denied-msg').classList.add('hidden')" class="text-slate-400 hover:text-slate-600 flex-shrink-0 leading-none text-lg -mt-0.5">&times;</button>
      </div>
    </div>
    <script>
    // ── Push prompt display + Allow button wiring ─────────────────────────────
    // This script tag sits immediately after the prompt HTML so the elements are
    // already in the DOM — no DOMContentLoaded race, no Turbo dependency.
    (function() {
      // Wire the Allow button with a fully self-contained click handler.
      // We do NOT rely on window.requestPushPermission so this works even if the
      // main push IIFE above failed or hasn't run yet.
      var allowBtn = document.getElementById('push-prompt-allow');
      if (allowBtn) {
        allowBtn.addEventListener('click', function() {
          if (!('Notification' in window)) return;

          allowBtn.disabled = true;
          allowBtn.textContent = '...';

          function afterPermission(permission) {
            var prompt = document.getElementById('push-prompt');
            if (prompt) prompt.remove();
            localStorage.setItem('push_prompt_dismissed', '1');

            if (permission === 'granted') {
              // Call the single subscribe function defined in the push IIFE above.
              // It reads vapid key fresh from the DOM and uses navigator.serviceWorker.ready.
              if (typeof window.doSubscribePush === 'function') {
                window.doSubscribePush();
              }
            } else {
              var denied = document.getElementById('push-denied-msg');
              if (denied) denied.classList.remove('hidden');
            }
          }

          // Call requestPermission — handle both Promise (modern) and callback (old Safari)
          var req;
          try {
            req = Notification.requestPermission(function(p) {
              // Old Safari callback path — only fires if req is undefined/not-a-Promise
              afterPermission(p);
            });
          } catch(e) {
            console.warn('[Push] requestPermission threw:', e);
            allowBtn.disabled = false;
            allowBtn.textContent = 'Allow';
            return;
          }

          if (req && typeof req.then === 'function') {
            // Modern browsers: use the returned Promise
            req.then(afterPermission).catch(function() {
              allowBtn.disabled = false;
              allowBtn.textContent = 'Allow';
            });
          }
        });
      }

      // Show the prompt after a short delay (skip during onboarding)
      var vapidKey = document.querySelector('meta[name="vapid-public-key"]');
      if (!vapidKey || !('Notification' in window) || !('PushManager' in window)) return;
      if (Notification.permission !== 'default') return;
      if (localStorage.getItem('push_prompt_dismissed')) return;
      if (document.getElementById('onboarding-overlay')) return;
      setTimeout(function() {
        if (document.getElementById('onboarding-overlay')) return;
        var el = document.getElementById('push-prompt');
        if (el) el.classList.remove('hidden');
      }, 3000);
    })();
    </script>
    <% end %>

  </body>
</html>
