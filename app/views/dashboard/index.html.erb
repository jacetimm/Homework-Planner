      </div>
      <p class="mt-5 text-center text-xs text-slate-400">
        By signing in, you agree to our
        <%= link_to "Terms of Service", "/terms", class: "font-semibold text-slate-500 hover:text-indigo-600 underline underline-offset-2 transition-colors" %>
