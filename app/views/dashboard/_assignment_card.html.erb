<%# locals: a (assignment hash), accent_text, accent_border, due_text, danger_zone_ids (optional) %>
<%
  is_danger = defined?(danger_zone_ids) && danger_zone_ids&.include?(a[:course_work_id])
  due_date_obj = Date.parse(a[:due_date]) rescue nil
  days_left = due_date_obj ? (due_date_obj - Date.current).to_i : nil
%>
<div class="rounded-xl border <%= accent_border %> <%= is_danger ? 'ring-1 ring-rose-500/60' : '' %> bg-black/10 p-3">

  <!-- Danger zone warning -->
  <% if is_danger %>
    <div class="flex items-center gap-1.5 mb-2 bg-rose-500/20 border border-rose-500/30 rounded-lg px-2 py-1.5">
      <svg class="w-3.5 h-3.5 text-rose-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
      <p class="text-[10px] font-bold text-rose-200 leading-tight">
        <%= days_left == 0 ? "Due today" : days_left == 1 ? "Due tomorrow" : "Due in #{days_left} days" %> &middot; <%= format_minutes(a[:estimated_minutes]) %> &middot; not started &mdash; don't wait
      </p>
    </div>
  <% end %>

  <!-- Course label + tonight's time -->
  <div class="flex items-center justify-between gap-2">
    <p class="text-[11px] font-bold uppercase tracking-wider <%= accent_text %> truncate"><%= a[:course] %></p>
    <span class="text-xs font-bold text-white/90 whitespace-nowrap"><%= format_minutes(a[:minutes]) %> tonight</span>
  </div>

  <!-- Title link -->
  <a href="<%= a[:assignment_link] %>" target="_blank" rel="noopener" class="block hover:opacity-75 transition">
    <p class="text-sm font-semibold text-white leading-snug mt-1 line-clamp-2"><%= a[:title] %></p>
  </a>

  <!-- Status badges row -->
  <div class="flex flex-wrap items-center gap-1.5 mt-2">
    <span class="text-[10px] font-bold px-2 py-0.5 rounded border border-white/10 <%= due_text %> bg-white/5">Due <%= format_due_date(Date.parse(a[:due_date])) %></span>
    <% if a[:urgency] == "overdue" %>
      <span class="text-[10px] font-bold px-2 py-0.5 rounded border bg-rose-500/30 text-rose-200 border-rose-400/40">Overdue</span>
    <% end %>
    <button
      class="start-timer-btn text-[10px] font-extrabold px-2.5 py-0.5 rounded-lg bg-emerald-500/20 hover:bg-emerald-500/35 text-emerald-300 border border-emerald-500/40 transition cursor-pointer flex items-center gap-1 whitespace-nowrap"
      data-course-work-id="<%= a[:course_work_id] %>"
      data-title="<%= CGI.escapeHTML(a[:title].to_s) %>"
      data-course="<%= CGI.escapeHTML(a[:course].to_s) %>"
      data-minutes="<%= a[:estimated_minutes].to_i %>">
      &#9201; Start timer
    </button>
    <button
      class="crunch-btn ml-auto text-[10px] font-extrabold px-2.5 py-0.5 rounded-lg <%= is_danger ? 'bg-rose-500 hover:bg-rose-400 text-white border border-rose-400 animate-pulse' : 'bg-violet-500/30 hover:bg-violet-500/50 text-violet-200 border border-violet-500/40' %> transition cursor-pointer flex items-center gap-1 whitespace-nowrap"
      data-course-work-id="<%= a[:course_work_id] %>"
      data-title="<%= CGI.escapeHTML(a[:title].to_s) %>"
      data-course="<%= CGI.escapeHTML(a[:course].to_s) %>"
      data-minutes="<%= a[:estimated_minutes].to_i %>"
      data-due="<%= a[:due_date] %>">
      &#9889; Crunch Mode
    </button>
  </div>

  <!-- Night-by-night split plan -->
  <% if a[:split_plan]&.size.to_i > 1 %>
    <div class="mt-2 flex flex-wrap gap-1 items-center">
      <span class="text-[10px] text-white/40 font-semibold mr-0.5">Split across:</span>
      <% a[:split_plan].each_with_index do |chunk, i| %>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded <%= i == 0 ? 'bg-white/20 text-white border border-white/25' : 'bg-white/8 text-white/60 border border-white/10' %>"><%= chunk[:day_abbr] %>: <%= format_minutes(chunk[:minutes]) %></span>
      <% end %>
    </div>
  <% end %>
  <% if a[:no_buffer_day] %>
    <p class="mt-2 text-[10px] font-semibold text-amber-200">No buffer day, don't fall behind!</p>
  <% end %>

  <!-- Actions row -->
  <div class="flex flex-wrap items-center gap-2 mt-2.5 pt-2 border-t border-white/10">
    <div class="flex items-center gap-1.5">
      <%= button_to "↺ AI Re-estimate",
        reestimate_assignment_path(a[:course_work_id]),
        method: :post,
        data: { turbo: false },
        disabled: a[:reestimate_disabled],
        title: a[:reestimate_tooltip],
        class: "text-[10px] font-bold px-2 py-0.5 rounded border transition #{a[:reestimate_disabled] ? 'border-white/10 text-white/25 bg-white/5 cursor-not-allowed' : 'border-white/20 text-white/50 bg-white/5 hover:bg-white/15 hover:text-white/80 cursor-pointer'}" %>
      <span class="text-[10px] text-white/35 font-semibold whitespace-nowrap"><%= a[:daily_reestimates_left] || AssignmentReestimate::DAILY_LIMIT %>/<%= a[:daily_reestimates_limit] || AssignmentReestimate::DAILY_LIMIT %> left today</span>
    </div>

    <form action="<%= set_assignment_estimate_path(a[:course_work_id]) %>" method="post" data-turbo="false" class="flex items-center gap-1">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <span class="text-[10px] text-white/35 font-semibold">My est:</span>
      <input type="text" name="minutes" value="<%= format_minutes(a[:full_assignment_minutes]) %>" placeholder="3h 45m"
             class="text-[11px] w-20 bg-white/10 border border-white/20 rounded px-1.5 py-0.5 text-white text-center focus:outline-none focus:border-white/50 focus:bg-white/15">
      <button type="submit" class="text-[10px] font-bold px-2 py-0.5 rounded border border-white/20 text-white/50 bg-white/5 hover:bg-white/15 hover:text-white/80 transition cursor-pointer">Set</button>
    </form>
  </div>

</div>
