<main class="w-full max-w-4xl mx-auto flex-1 px-5 sm:px-8 py-8">

  <div class="mb-6">
    <h2 class="text-2xl font-extrabold text-slate-900 tracking-tight">Preferences</h2>
    <p class="text-slate-500 text-sm mt-1">Customize how Homework Planner schedules your study time.</p>
  </div>

  <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden pb-36 md:pb-20">
    <%= form_with model: @user_setting, url: settings_path, method: :patch, class: "divide-y divide-slate-100", id: "preferences-form" do |f| %>

      <!-- Section 0: Appearance -->
      <div class="p-4 sm:p-8">
        <h3 class="text-base font-bold text-slate-900 mb-0.5">Appearance</h3>
        <p class="text-sm text-slate-500 mb-5">Choose how the app looks. <em>Auto</em> follows your device setting.</p>
        <div class="flex gap-3">
          <% [["light","☀️","Light"],["dark","🌙","Dark"],["auto","💻","Auto"]].each do |val, icon, label| %>
            <button type="button"
                    data-theme-opt="<%= val %>"
                    onclick="setThemeOpt('<%= val %>')"
                    class="theme-opt-btn flex-1 rounded-2xl border-2 py-3 text-center transition
                           <%= @user_setting.color_theme == val ? 'border-indigo-500 bg-indigo-50 text-indigo-700' : 'border-slate-200 text-slate-600 hover:border-indigo-300' %>">
              <div class="text-xl mb-0.5"><%= icon %></div>
              <div class="text-xs font-bold"><%= label %></div>
            </button>
          <% end %>
        </div>
        <%= f.hidden_field :color_theme, id: "color-theme-input" %>
      </div>

      <!-- Section 1: Study Schedule -->
      <div class="p-4 sm:p-8">
        <h3 class="text-base font-bold text-slate-900 mb-0.5">Daily Study Schedule</h3>
        <p class="text-sm text-slate-500 mb-5">Set your preferred window for evening homework. Assignments will be scheduled during this block.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <%= f.label :study_start_time, "Start Time", class: "block text-sm font-bold text-slate-700 mb-1.5" %>
            <%= f.time_field :study_start_time, class: "w-full rounded-xl border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
          </div>
          <div>
            <%= f.label :study_end_time, "End Time", class: "block text-sm font-bold text-slate-700 mb-1.5" %>
            <%= f.time_field :study_end_time, class: "w-full rounded-xl border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
            <p class="text-xs text-slate-400 mt-1.5">Can be past midnight (e.g. 2:00 AM)</p>
          </div>
        </div>

        <div class="mt-5 pt-5 border-t border-slate-100">
          <h4 class="text-sm font-bold text-slate-700 mb-0.5">Max Time per Subject per Night</h4>
          <p class="text-xs text-slate-500 mb-3">Large assignments will be split across multiple nights so no single subject dominates your evening. Set to 0 to disable splitting.</p>
          <div class="flex items-center gap-3 max-w-xs">
            <div class="relative flex-1">
              <%= f.number_field :max_minutes_per_subject, min: 0, max: 240, class: "w-full rounded-xl border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 pr-16" %>
              <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                <span class="text-slate-400 text-sm font-medium">min</span>
              </div>
            </div>
            <span class="text-xs text-slate-500 font-medium whitespace-nowrap">per subject</span>
          </div>
        </div>
      </div>

      <!-- Section 2: Break Intervals -->
      <div class="p-4 sm:p-8 bg-slate-50/50">
        <h3 class="text-base font-bold text-slate-900 mb-0.5">Pomodoro & Breaks</h3>
        <p class="text-sm text-slate-500 mb-5">How often do you need a breather?</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <%= f.label :break_frequency, "Break Every", class: "block text-sm font-bold text-slate-700 mb-1.5" %>
            <div class="relative">
              <%= f.number_field :break_frequency, min: 0, class: "w-full rounded-xl border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 pr-16" %>
              <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                <span class="text-slate-400 text-sm font-medium">min</span>
              </div>
            </div>
          </div>
          <div>
            <%= f.label :break_duration, "Break Duration", class: "block text-sm font-bold text-slate-700 mb-1.5" %>
            <div class="relative">
              <%= f.number_field :break_duration, min: 0, class: "w-full rounded-xl border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 pr-16" %>
              <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                <span class="text-slate-400 text-sm font-medium">min</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Section 3: Hard Subjects -->
      <div class="p-4 sm:p-8">
        <h3 class="text-base font-bold text-slate-900 mb-0.5">Challenging Classes</h3>
        <p class="text-sm text-slate-500 mb-5">Toggle classes you struggle with. The planner will allocate <span class="font-semibold text-slate-700">25% more time</span> for these subjects.</p>

        <%# Hidden input ensures empty array is submitted when all are unchecked %>
        <input type="hidden" name="user_setting[hard_subjects][]" value="">

        <% if @active_courses.present? %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <% @active_courses.each do |course| %>
              <% is_hard = @user_setting.hard_subjects.include?(course.name) %>
              <label class="flex items-center gap-3 rounded-xl border px-4 py-3 cursor-pointer transition select-none <%= is_hard ? 'border-indigo-300 bg-indigo-50' : 'border-slate-200 bg-white hover:bg-slate-50' %>">
                <%= check_box_tag "user_setting[hard_subjects][]", course.name, is_hard, id: "subject_#{course.id}", class: "w-5 h-5 text-indigo-600 border-slate-300 rounded focus:ring-indigo-500" %>
                <span class="text-sm font-semibold text-slate-800 flex-1"><%= course.name %></span>
                <% if is_hard %>
                  <span class="text-[10px] font-bold text-indigo-600 bg-indigo-100 px-2 py-0.5 rounded-full border border-indigo-200">+25%</span>
                <% end %>
              </label>
            <% end %>
          </div>
        <% else %>
          <div class="p-4 bg-slate-50 rounded-xl border border-slate-200 border-dashed text-sm text-slate-500">
            No active classes found. These are pulled directly from Google Classroom during your sync.
          </div>
        <% end %>
      </div>

      <!-- Section 4: Extracurriculars -->
      <div class="p-4 sm:p-8 bg-slate-50/50">
        <div class="flex items-center justify-between mb-5">
          <div>
            <h3 class="text-base font-bold text-slate-900 mb-0.5">Extracurricular Blocks</h3>
            <p class="text-sm text-slate-500">Add sports, clubs, or jobs. Homework will NOT be scheduled during these times.</p>
          </div>
          <button type="button" onclick="addExtracurricularRow()" class="px-4 py-2 bg-indigo-50 text-indigo-700 rounded-lg text-sm font-bold border border-indigo-100 hover:bg-indigo-100 transition flex-shrink-0">
            + Add Block
          </button>
        </div>

        <div id="extracurriculars-container" class="space-y-4">
          <% @user_setting.extracurricular_blocks.each_with_index do |block, index| %>
            <%
              existing_days_raw = block['days'] || block[:days] || ""
              existing_days = case existing_days_raw
              when Array then existing_days_raw.map(&:to_s)
              when String then existing_days_raw.split(",").map(&:strip)
              else []
              end
              day_map = { "monday" => "Mon", "tuesday" => "Tue", "wednesday" => "Wed", "thursday" => "Thu", "friday" => "Fri", "saturday" => "Sat", "sunday" => "Sun" }
              existing_days = existing_days.map { |d| day_map[d.downcase] || d[0,3].capitalize }.uniq
              days_value = existing_days.join(", ")
            %>
            <div class="extracurricular-row bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
              <div class="flex flex-col md:flex-row gap-4 items-end">
                <div class="flex-1 w-full">
                  <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Activity Name</label>
                  <input type="text" name="user_setting[extracurricular_blocks][<%= index %>][activity]" value="<%= block['activity'] %>" class="w-full rounded-lg border-slate-300 text-sm focus:border-indigo-500 focus:ring-indigo-500" placeholder="e.g. Soccer Practice">
                </div>
                <div class="w-full md:w-auto">
                  <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Start Time</label>
                  <input type="time" name="user_setting[extracurricular_blocks][<%= index %>][start_time]" value="<%= block['start_time'] %>" class="w-full rounded-lg border-slate-300 text-sm focus:border-indigo-500 focus:ring-indigo-500">
                </div>
                <div class="w-full md:w-auto">
                  <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">End Time</label>
                  <input type="time" name="user_setting[extracurricular_blocks][<%= index %>][end_time]" value="<%= block['end_time'] %>" class="w-full rounded-lg border-slate-300 text-sm focus:border-indigo-500 focus:ring-indigo-500">
                </div>
                <button type="button" onclick="this.closest('.extracurricular-row').remove()" class="p-2 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition flex-shrink-0 mb-0.5">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </button>
              </div>
              <!-- Weekday Pill Picker -->
              <div class="mt-3">
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Days</label>
                <input type="hidden" name="user_setting[extracurricular_blocks][<%= index %>][days]" value="<%= days_value %>" class="days-hidden-input" id="days_<%= index %>">
                <div class="flex flex-wrap gap-1.5 day-pill-group" data-target="days_<%= index %>">
                  <% %w[Mon Tue Wed Thu Fri Sat Sun].each do |d| %>
                    <% active = existing_days.map { |x| x[0,3].downcase }.include?(d.downcase) %>
                    <button type="button" onclick="toggleDayPill(this)" data-day="<%= d %>" class="day-pill px-3 py-1 rounded-lg text-xs font-bold border transition <%= active ? 'bg-indigo-600 text-white border-indigo-600 shadow-sm' : 'bg-white text-slate-500 border-slate-300 hover:border-indigo-400 hover:text-indigo-600' %>"><%= d %></button>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <p class="text-[11px] text-slate-400 font-medium mt-4">Use these for recurring blocks not already on your Google Calendar.</p>
      </div>

      <!-- Section 5: Google Calendar -->
      <div class="p-4 sm:p-8">
        <h3 class="text-base font-bold text-slate-900 mb-0.5">Google Calendar Blocking</h3>
        <p class="text-sm text-slate-500 mb-5">Block homework time around specific Google Calendar events. Choose which calendars to include, then optionally filter out individual events by keyword.</p>

        <div class="space-y-6">
          <label class="flex items-start gap-3 rounded-2xl border border-slate-200 p-4 bg-slate-50/60 cursor-pointer hover:bg-slate-50 transition">
            <%= f.check_box :block_google_calendar_events, class: "mt-0.5 h-5 w-5 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
            <div>
              <p class="text-sm font-bold text-slate-800">Block homework around Google Calendar events</p>
              <p class="text-xs text-slate-500 mt-1">Uses the Google account you already signed in with — no extra API key needed.</p>
            </div>
          </label>

          <div>
            <div class="flex items-center justify-between gap-3 mb-3 flex-wrap">
              <div>
                <p class="text-sm font-bold text-slate-700">Include These Calendars</p>
                <p class="text-xs text-slate-500 mt-0.5">Check each calendar whose events should block your homework time. Unchecked calendars are fully ignored.</p>
              </div>
              <% if @google_calendars.size > 5 %>
                <input type="text" id="calendar-search" oninput="filterCalendars(this.value)" placeholder="Search calendars…" class="text-xs rounded-lg border-slate-300 focus:border-indigo-500 focus:ring-indigo-500 py-1.5 px-3 w-44">
              <% end %>
            </div>
            <% if @google_calendars.present? %>
              <%# Hidden field so the controller gets an empty array when nothing is checked %>
              <input type="hidden" name="user_setting[included_google_calendar_ids][]" value="">
              <div id="calendar-list" class="space-y-2">
                <% @google_calendars.each do |calendar| %>
                  <% is_included = !@user_setting.ignored_google_calendar_ids.include?(calendar[:id]) %>
                  <label class="calendar-item flex items-center gap-3 rounded-xl border px-4 py-3 cursor-pointer transition <%= is_included ? 'border-indigo-300 bg-indigo-50/60 hover:bg-indigo-50 dark:border-indigo-600 dark:bg-indigo-900/30 dark:hover:bg-indigo-900/50' : 'border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700/40' %>" data-name="<%= calendar[:summary].to_s.downcase %>">
                    <%= check_box_tag "user_setting[included_google_calendar_ids][]", calendar[:id], is_included, id: "included_calendar_#{calendar[:id].parameterize}", class: "h-5 w-5 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 flex-shrink-0" %>
                    <p class="text-sm font-semibold text-slate-800 flex-1 truncate"><%= calendar[:summary] %></p>
                    <span class="text-[10px] font-bold px-2 py-0.5 rounded-full border flex-shrink-0 <%= calendar[:primary] ? 'bg-indigo-50 text-indigo-600 border-indigo-200 dark:bg-indigo-900/40 dark:text-indigo-400 dark:border-indigo-700' : 'bg-slate-100 text-slate-500 border-slate-200 dark:bg-slate-700 dark:text-slate-400 dark:border-slate-600' %>">
                      <%= calendar[:primary] ? "Primary" : "Shared" %>
                    </span>
                  </label>
                <% end %>
              </div>
            <% else %>
              <div class="rounded-xl border border-slate-200 border-dashed bg-slate-50 p-4 text-sm text-slate-500">
                Calendar list unavailable right now. All calendars on your account will be used for blocking.
              </div>
            <% end %>
          </div>

          <div>
            <div class="flex items-center justify-between gap-4 mb-3 flex-wrap">
              <div>
                <label class="block text-sm font-bold text-slate-700">Ignore Rules</label>
                <p class="text-xs text-slate-500 mt-0.5">Match a keyword and choose which calendar the rule applies to.</p>
              </div>
              <button type="button" onclick="addCalendarIgnoreRule()" class="px-4 py-2 bg-indigo-50 text-indigo-700 rounded-lg text-sm font-bold border border-indigo-100 hover:bg-indigo-100 transition flex-shrink-0">
                + Add Rule
              </button>
            </div>

            <div id="calendar-ignore-rules-container" class="space-y-2">
              <% existing_rules = (@user_setting.calendar_ignore_rules.presence || []).reject { |r| r["keyword"].blank? && r["calendar_id"].blank? } %>
              <% existing_rules.each_with_index do |rule, index| %>
                <div class="calendar-ignore-rule bg-slate-50 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 rounded-xl p-3 flex flex-col sm:flex-row gap-3 items-end">
                  <div class="flex-1 w-full">
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Keyword</label>
                    <input type="text" name="user_setting[calendar_ignore_rules][<%= index %>][keyword]" value="<%= rule["keyword"] %>" class="w-full rounded-lg border-slate-300 text-sm focus:border-indigo-500 focus:ring-indigo-500" placeholder="e.g. dentist">
                  </div>
                  <div class="flex-1 w-full">
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Calendar</label>
                    <select name="user_setting[calendar_ignore_rules][<%= index %>][calendar_id]" class="w-full rounded-lg border-slate-300 text-sm focus:border-indigo-500 focus:ring-indigo-500">
                      <option value="">Any Calendar</option>
                      <% @google_calendars.each do |calendar| %>
                        <option value="<%= calendar[:id] %>" <%= "selected" if rule["calendar_id"].to_s == calendar[:id].to_s %>><%= calendar[:summary] %></option>
                      <% end %>
                    </select>
                  </div>
                  <button type="button" onclick="this.closest('.calendar-ignore-rule').remove()" class="p-2 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  </button>
                </div>
              <% end %>
            </div>
            <p class="text-xs text-slate-400 mt-2">Example: keyword <code class="bg-slate-100 px-1 rounded">dentist</code> on <em>Any Calendar</em> ignores all events with that word.</p>
          </div>
        </div>
      </div>

      <!-- Section 6: Timezone -->
      <div class="p-4 sm:p-8">
        <h3 class="text-base font-bold text-slate-900 mb-0.5">Timezone</h3>
        <p class="text-sm text-slate-500 mb-5">Used for scheduling, due-date urgency, and timeline time slots. Auto-detected from your browser on first login.</p>

        <div class="max-w-sm">
          <label class="block text-sm font-bold text-slate-700 mb-1.5" for="user_timezone">Your Timezone</label>
          <%= select_tag :timezone,
                options_for_select(
                  ActiveSupport::TimeZone.all.sort_by(&:utc_offset).map { |tz|
                    ["(#{tz.formatted_offset}) #{tz.name}", tz.name]
                  },
                  current_user.timezone.presence || "Eastern Time (US & Canada)"
                ),
                id: "user_timezone",
                class: "w-full rounded-xl border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
          <p class="text-xs text-slate-400 mt-2">Changes take effect on your next page load.</p>
        </div>
      </div>

      <!-- Section: Push Notifications -->
      <div class="p-4 sm:p-8" id="notifications-section">
        <h3 class="text-base font-bold text-slate-900 mb-0.5">Push Notifications</h3>
        <p class="text-sm text-slate-500 mb-5">Get a nudge on your phone when an assignment is due soon and you haven't started yet.</p>

        <label class="flex items-center gap-4 cursor-pointer group">
          <%= f.check_box :push_notifications_enabled,
                          class: "sr-only peer",
                          id: "push_notifications_toggle",
                          onchange: "window.togglePushNotifications && window.togglePushNotifications(this.checked)" %>
          <div class="relative w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-indigo-400 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600 flex-shrink-0"></div>
          <div>
            <p class="text-sm font-bold text-slate-800 group-hover:text-indigo-600 transition">Enable push notifications</p>
            <p class="text-xs text-slate-500 mt-0.5">Reminders are only sent for assignments due within 24 hours that you haven't started.</p>
          </div>
        </label>

        <div id="push-status-msg" class="mt-3 text-xs text-slate-400"></div>
        <script>
          (function() {
            var el = document.getElementById('push-status-msg');
            if (!el || !('Notification' in window)) return;
            if (Notification.permission === 'denied') {
              el.textContent = 'Notifications are blocked in your browser settings. To re-enable, update your browser permissions for this site.';
              el.classList.add('text-rose-500');
            } else if (Notification.permission === 'granted') {
              el.textContent = 'Browser notifications are enabled.';
              el.classList.add('text-emerald-600');
            }
          })();
        </script>
      </div>

      <!-- Section 7: Feature Visibility -->
      <div class="p-4 sm:p-8">
        <h3 class="text-base font-bold text-slate-900 mb-0.5">Feature Visibility</h3>
        <p class="text-sm text-slate-500 mb-5">By default, advanced features unlock gradually as you use the app. Turn this on to see everything immediately.</p>

        <label class="flex items-center gap-4 cursor-pointer group">
          <%= f.check_box :show_all_features, class: "sr-only peer", id: "show_all_features_toggle" %>
          <div class="relative w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-indigo-400 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600 flex-shrink-0"></div>
          <div>
            <p class="text-sm font-bold text-slate-800 group-hover:text-indigo-600 transition">Show all features</p>
            <p class="text-xs text-slate-500 mt-0.5">Unlock everything now instead of gradually. Great for power users.</p>
          </div>
        </label>
      </div>

    <% end %>

    <!-- Section 8: Hidden Assignments -->
    <% hidden_items = current_user.hidden_assignments.order(hidden_at: :desc) %>
    <% if hidden_items.any? %>
      <div class="p-4 sm:p-8 border-t border-slate-100" id="hidden_assignments_section">
        <h3 class="text-base font-bold text-slate-900 mb-0.5">Hidden Assignments</h3>
        <p class="text-sm text-slate-500 mb-5">These assignments have been hidden from your dashboard. You can unhide them here.</p>

        <div class="space-y-3">
          <% hidden_items.each do |hidden_assignment| %>
            <div id="hidden_assignment_row_<%= hidden_assignment.course_work_id %>" class="flex items-center justify-between gap-4 p-4 rounded-xl border border-slate-200 bg-slate-50 shadow-[inset_0_1px_0_rgba(255,255,255,1)]">
              <div class="min-w-0 flex-1">
                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-0.5 truncate"><%= hidden_assignment.course_name %></p>
                <p class="text-sm font-semibold text-slate-900 truncate"><%= hidden_assignment.assignment_title %></p>
              </div>
              <%= button_to "Show again", hidden_assignment_path(hidden_assignment.course_work_id), method: :delete, class: "flex-shrink-0 text-xs font-bold bg-white hover:bg-slate-100 text-indigo-600 border border-slate-300 hover:border-indigo-300 rounded-lg px-3 py-2 transition shadow-sm whitespace-nowrap cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>

  <!-- Sticky Save Bar -->
  <div class="fixed bottom-16 md:bottom-0 left-0 right-0 z-40 bg-white/95 dark:bg-slate-900/95 backdrop-blur border-t border-slate-200 dark:border-slate-700 shadow-lg">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 py-3 flex items-center justify-between gap-4">
      <p class="text-sm text-slate-500 hidden sm:block">Customize how your homework gets scheduled.</p>
      <button type="submit" form="preferences-form" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-8 rounded-xl shadow-sm transition duration-150 cursor-pointer ml-auto">
        Save Preferences
      </button>
    </div>
  </div>

</main>

<script>
  let extraIndex = <%= @user_setting.extracurricular_blocks.size %>;
  let calendarRuleIndex = <%= [(@user_setting.calendar_ignore_rules.presence || []).reject { |r| r["keyword"].blank? && r["calendar_id"].blank? }.size, 0].max %>;
  const calendarOptionsHtml = `<option value="">Any Calendar</option><%= j(@google_calendars.map { |calendar| "<option value=\"#{h(calendar[:id])}\">#{h(calendar[:summary])}</option>" }.join) %>`;
  const DAYS = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

  function setThemeOpt(val) {
    document.getElementById('color-theme-input').value = val;
    document.querySelectorAll('.theme-opt-btn').forEach(function(b) {
      var active = b.dataset.themeOpt === val;
      b.className = b.className.replace(/border-indigo-500 bg-indigo-50 text-indigo-700|border-slate-200 text-slate-600 hover:border-indigo-300/g, '').trim();
      b.className += active ? ' border-indigo-500 bg-indigo-50 text-indigo-700' : ' border-slate-200 text-slate-600 hover:border-indigo-300';
    });
    // Apply immediately for live preview
    var dark = val === 'dark' || (val === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
    document.documentElement.classList.toggle('dark', dark);
  }

  function toggleDayPill(btn) {
    const active = btn.classList.contains('bg-indigo-600');
    if (active) {
      btn.classList.remove('bg-indigo-600', 'text-white', 'border-indigo-600', 'shadow-sm');
      btn.classList.add('bg-white', 'text-slate-500', 'border-slate-300', 'hover:border-indigo-400', 'hover:text-indigo-600');
    } else {
      btn.classList.remove('bg-white', 'text-slate-500', 'border-slate-300', 'hover:border-indigo-400', 'hover:text-indigo-600');
      btn.classList.add('bg-indigo-600', 'text-white', 'border-indigo-600', 'shadow-sm');
    }
    const group = btn.closest('.day-pill-group');
    const targetId = group.dataset.target;
    const selected = [...group.querySelectorAll('.day-pill.bg-indigo-600')].map(b => b.dataset.day);
    document.getElementById(targetId).value = selected.join(', ');
  }

  function pillsHtml(index) {
    return DAYS.map(d => `<button type="button" onclick="toggleDayPill(this)" data-day="${d}" class="day-pill px-3 py-1 rounded-lg text-xs font-bold border transition bg-white text-slate-500 border-slate-300 hover:border-indigo-400 hover:text-indigo-600">${d}</button>`).join('');
  }

  function addExtracurricularRow() {
    const container = document.getElementById('extracurriculars-container');
    const html = `
      <div class="extracurricular-row bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
        <div class="flex flex-col md:flex-row gap-4 items-end">
          <div class="flex-1 w-full">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Activity Name</label>
            <input type="text" name="user_setting[extracurricular_blocks][${extraIndex}][activity]" class="w-full rounded-lg border-slate-300 text-sm focus:border-indigo-500 focus:ring-indigo-500" placeholder="e.g. Soccer Practice">
          </div>
          <div class="w-full md:w-auto">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">Start Time</label>
            <input type="time" name="user_setting[extracurricular_blocks][${extraIndex}][start_time]" class="w-full rounded-lg border-slate-300 text-sm focus:border-indigo-500 focus:ring-indigo-500">
          </div>
          <div class="w-full md:w-auto">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5">End Time</label>
            <input type="time" name="user_setting[extracurricular_blocks][${extraIndex}][end_time]" class="w-full rounded-lg border-slate-300 text-sm focus:border-indigo-500 focus:ring-indigo-500">
          </div>
          <button type="button" onclick="this.closest('.extracurricular-row').remove()" class="p-2 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition flex-shrink-0 mb-0.5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
          </button>
        </div>
        <div class="mt-3">
          <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Days</label>
          <input type="hidden" name="user_setting[extracurricular_blocks][${extraIndex}][days]" value="" id="days_${extraIndex}">
          <div class="flex flex-wrap gap-1.5 day-pill-group" data-target="days_${extraIndex}">
            ${pillsHtml(extraIndex)}
          </div>
        </div>
      </div>
    `;
    container.insertAdjacentHTML('beforeend', html);
    extraIndex++;
  }

  function addCalendarIgnoreRule() {
    const container = document.getElementById('calendar-ignore-rules-container');
    const html = `
      <div class="calendar-ignore-rule bg-slate-50 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700 rounded-xl p-3 flex flex-col sm:flex-row gap-3 items-end">
        <div class="flex-1 w-full">
          <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Keyword</label>
          <input type="text" name="user_setting[calendar_ignore_rules][${calendarRuleIndex}][keyword]" class="w-full rounded-lg border-slate-300 text-sm focus:border-indigo-500 focus:ring-indigo-500" placeholder="e.g. dentist">
        </div>
        <div class="flex-1 w-full">
          <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Calendar</label>
          <select name="user_setting[calendar_ignore_rules][${calendarRuleIndex}][calendar_id]" class="w-full rounded-lg border-slate-300 text-sm focus:border-indigo-500 focus:ring-indigo-500">
            ${calendarOptionsHtml}
          </select>
        </div>
        <button type="button" onclick="this.closest('.calendar-ignore-rule').remove()" class="p-2 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition flex-shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </button>
      </div>
    `;
    container.insertAdjacentHTML('beforeend', html);
    calendarRuleIndex++;
  }

  function filterCalendars(query) {
    const items = document.querySelectorAll('.calendar-item');
    const q = query.toLowerCase().trim();
    items.forEach(item => {
      item.style.display = (!q || (item.dataset.name || '').includes(q)) ? '' : 'none';
    });
  }
</script>
